# --- VCL Reference Implementation environment template ---
# Copy to `.env` and fill in. `docker compose` reads this file automatically.

# Anthropic Claude API key — used by the agent runtime as the LLM backbone.
# If left blank, the agent falls back to a deterministic response synthesiser
# so the demo and test suite still run end-to-end without a key.
ANTHROPIC_API_KEY=

# Claude model id (default is the latest Sonnet).
VCL_LLM_MODEL=claude-sonnet-4-6

# Optional: OpenAI key for cross-LLM comparison testing. Not required.
OPENAI_API_KEY=

# --- Internal service URLs (defaults match docker-compose; override only if needed) ---
VCL_SEMANTIC_URL=http://semantic-layer:4000
VCL_GRAPH_BOLT_URI=bolt://context-graph:7687
VCL_GRAPH_USER=neo4j
VCL_GRAPH_PASSWORD=vcldemopassword
VCL_POLICY_URL=http://policy-engine:8181
VCL_FEEDBACK_URL=http://feedback-loop:8200
VCL_AGENT_URL=http://agent-runtime:8000

# Demo principal (single demo user — no auth in this MVP).
VCL_DEMO_USER=demo-analyst
VCL_DEMO_PURPOSE=supplier_risk_review

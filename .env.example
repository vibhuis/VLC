# --- VCL Reference Implementation environment template ---
# Copy to `.env` and fill in. `docker compose` reads this file automatically.

# --- LLM (provider-agnostic via LiteLLM) ---
# Pick any model and supply its provider key below. If no key is set, the agent uses a
# deterministic fallback so the demo and tests still run end-to-end.
#
# VCL_LLM_MODEL examples:
#   gpt-4o                     (OpenAI — default; needs OPENAI_API_KEY)
#   gpt-4o                     (OpenAI — needs OPENAI_API_KEY)
#   gemini/gemini-1.5-pro      (Google — needs GEMINI_API_KEY)
#   groq/llama-3.3-70b-versatile  (Groq — needs GROQ_API_KEY)
#   ollama/llama3              (local Ollama — no key)
VCL_LLM_MODEL=gpt-4o

# Provide the key for whichever provider your model uses (leave the rest blank).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=

# --- Internal service URLs (defaults match docker-compose; override only if needed) ---
VCL_SEMANTIC_URL=http://semantic-layer:4000
VCL_GRAPH_BOLT_URI=bolt://context-graph:7687
VCL_GRAPH_USER=neo4j
VCL_GRAPH_PASSWORD=vcldemopassword
VCL_POLICY_URL=http://policy-engine:8181
VCL_FEEDBACK_URL=http://feedback-loop:8200
VCL_AGENT_URL=http://agent-runtime:8000

# Demo principal (single demo user — no auth in this MVP).
VCL_DEMO_USER=demo-analyst
VCL_DEMO_PURPOSE=supplier_risk_review

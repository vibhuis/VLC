# Neo4j Community that self-seeds the VCL context graph on first start. [spec §5.2]
FROM neo4j:5.23-community

# Seed Cypher (generated by data/synthetic/generate.py, landed in Phase 2).
COPY seed/load.cypher /seed/load.cypher
COPY seed/seed-entrypoint.sh /seed/seed-entrypoint.sh
RUN chmod +x /seed/seed-entrypoint.sh

# Wrap the stock entrypoint: start Neo4j, wait for bolt, run the seed once, stay up.
ENTRYPOINT ["/seed/seed-entrypoint.sh"]
CMD ["neo4j"]
